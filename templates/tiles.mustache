{{!
    Renders the dynamic homepage tiles grid.

    Context:
    - tiles (array): list of tile objects, each with:
        - colcls       (string)  Bootstrap column classes, same for all tiles.
        - has_link     (bool)    Whether the tile is wrapped in an anchor.
        - link         (string)  URL for the anchor (already cleaned via PARAM_URL).
        - newtab       (bool)    Open link in a new tab.
        - color        (string)  CSS modifier: blue|green|orange|purple|red|teal.
        - has_icon     (bool)
        - icon         (string)  Font Awesome icon name without "fa-" prefix.
        - has_value    (bool)
        - value        (string)  Pre-escaped display value (count or custom text).
        - title        (string)  Processed by format_string() — output unescaped.
        - has_subtitle (bool)
        - subtitle     (string)  Processed by format_string() — output unescaped.

    @template local_homepage_config/tiles
    @copyright 2026 Carlos Costa
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="block-homepage-tiles">
    <div class="row">
        {{#tiles}}
        <div class="{{colcls}} mb-4">
            {{#has_link}}<a href="{{link}}"{{#newtab}} target="_blank" rel="noopener noreferrer"{{/newtab}} class="text-decoration-none d-block h-100">{{/has_link}}
            <div class="card h-100 border-0 shadow-sm hpt-tile hpt-tile--{{color}}">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-4">
                    {{#has_icon}}<div class="hpt-tile__icon mb-3"><i class="fa fa-{{icon}} fa-3x" aria-hidden="true"></i></div>{{/has_icon}}
                    {{#has_value}}<div class="hpt-tile__value display-4 font-weight-bold mb-1">{{{value}}}</div>{{/has_value}}
                    <div class="hpt-tile__title h5 mb-1">{{{title}}}</div>
                    {{#has_subtitle}}<div class="hpt-tile__subtitle text-muted small">{{{subtitle}}}</div>{{/has_subtitle}}
                </div>
            </div>
            {{#has_link}}</a>{{/has_link}}
        </div>
        {{/tiles}}
    </div>
</div>
